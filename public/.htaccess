<IfModule mod_rewrite.c>
  RewriteEngine On
  
  # 1. Ensure Apache serves the index.html inside the directories
  DirectoryIndex index.html

  # 2. Permanent 301 Redirect: Root to English Hub
  RewriteRule ^$ /en/ [R=301,L]

  # 3. Enforce Trailing Slashes (Matches Next.js trailingSlash: true config)
  # If it's not a physical file, and doesn't end in a slash, add the slash.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_URI} !/$
  RewriteRule ^(.*)$ /$1/ [R=301,L]

  # 4. Serve the Next.js 404 page for missing routes
  ErrorDocument 404 /404.html
</IfModule>

# ─────────────────────────────────────────────────────────────
# Aggressive Cache Lifetimes for Static Assets
# ─────────────────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"
  ExpiresByType video/mp4 "access plus 1 year"
</IfModule>

# ─────────────────────────────────────────────────────────────
# Compression (GZIP/Brotli)
# ─────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# ─────────────────────────────────────────────────────────────
# Security Headers
# ─────────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>
